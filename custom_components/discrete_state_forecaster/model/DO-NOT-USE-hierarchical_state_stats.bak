import math
import time
from collections import defaultdict
from typing import Self

from custom_components.discrete_state_forecaster.model.state import State
from custom_components.discrete_state_forecaster.model.state_stats import (
    StateStats,
)
from custom_components.discrete_state_forecaster.model.time_indexers.time_key import (
    TimeKey,
)


class HierarchicalStateStats:

    def __init__(self, half_life: float) -> None:
        self.stats: dict[TimeKey, StateStats] = {}
        self.global_key: TimeKey = (("global", 1),)
        self.update_counter: int = 0
        self.half_life: float = half_life

    # --------------------------------------------------
    # helpers
    # --------------------------------------------------

    def _get_or_create(self, key: TimeKey) -> StateStats:
        if key not in self.stats:
            self.stats[key] = StateStats()

        return self.stats[key]

    def _hierarchy(self, key: TimeKey) -> list[TimeKey]:
        parts = list(key)
        result = []

        # progressively drop features from right
        for i in range(len(parts), 0, -1):
            result.append(tuple(parts[:i]))

        result.append(self.global_key)

        return result

    def update(
        self,
        key: TimeKey,
        state: State,
        duration: float,
        ts: float,
    ):
        for hkey in self._hierarchy(key):
            stats = self._get_or_create(hkey)
            self._apply_decay(stats, ts)
            stats.update_duration(state, duration)

        self.update_counter += 1

        if self.update_counter % 50 == 0:
            for stats in self.stats.values():
                stats.prune_adaptive()

    def distribution(
        self,
        key: TimeKey,
        min_support: float = 600,
    ) -> dict[State, float]:

        candidates: list[StateStats] = []

        for hkey in self._hierarchy(key):

            stats = self.stats.get(hkey)

            if stats and stats.total() >= min_support:
                candidates.append(stats)

        if not candidates:
            global_stats = self.stats.get(self.global_key)
            return global_stats.distribution() if global_stats else {}

        # duration-based weights
        weights = [math.sqrt(s.total()) for s in candidates]
        Z = sum(weights)
        weights = [w / Z for w in weights]

        merged: dict[State, float] = defaultdict(float)

        for stats, w in zip(candidates, weights, strict=True):
            for state, p in stats.distribution().items():
                merged[state] += w * p

        # normalize
        Z = sum(merged.values())

        if Z > 0:
            for s in merged:
                merged[s] /= Z

        return dict(merged)

    def _apply_decay(self, stats: StateStats, now_ts: float):
        stats.apply_decay(now_ts, self.half_life)
